# 관리자 페이지(/admin) 비밀번호
#
# [로컬] 이 파일을 복사해 .env.local 로 저장 → 값 변경 → npm run dev 재시작
# [Vercel] Project Settings → Environment Variables → ADMIN_PASSWORD 등록 → Redeploy
#
# .env.local 은 Git에 올라가지 않습니다.

ADMIN_PASSWORD=여기에-관리자-비밀번호-입력

# ---------------------------------------------------------------------------
# 데일리 크롤 (scripts/run_daily_crawl.bat / 작업 스케줄러 09:15 KST)
# ---------------------------------------------------------------------------

# ntfy 푸시 — 앱에서 구독한 토픽 이름 (다른 사람이 추측하기 어렵게)
NTFY_TOPIC=bio-news-본인만-아는-토픽-이름

# Vercel 배포 사이트 (알림 링크용, 끝에 / 없이)
VERCEL_PRODUCTION_URL=https://본인-프로젝트.vercel.app

# (선택) Vercel 배포 READY 될 때까지 대기 후 알림
# VERCEL_TOKEN=vercel_...
# VERCEL_PROJECT_ID=prj_...

# (선택) Telegram 대신/추가 알림
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# ---------------------------------------------------------------------------
# Admin 크롤 설정 GitHub 저장 (/admin/crawl-settings)
# [Vercel] Project Settings → Environment Variables
# ---------------------------------------------------------------------------

# GitHub Personal Access Token (repo Contents read/write)
# GITHUB_TOKEN=ghp_...

# owner/repo 형식
# GITHUB_REPO=your-user/bio-news-report
