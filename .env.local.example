# 관리자 페이지(/admin) 비밀번호
#
# [로컬] 이 파일을 복사해 .env.local 로 저장 → 값 변경 → npm run dev 재시작
# [Vercel] Project Settings → Environment Variables → ADMIN_PASSWORD 등록 → Redeploy
#
# .env.local 은 Git에 올라가지 않습니다.

ADMIN_PASSWORD=여기에-관리자-비밀번호-입력

# ---------------------------------------------------------------------------
# 로컬에서 크롤러 실행 시 (python scripts/collect_news.py)
# GitHub Actions에서는 Repository Secrets에 동일 키를 등록하세요.
# ---------------------------------------------------------------------------

# OpenAI API 키 (ChatGPT Plus 구독과 별도 — platform.openai.com)
OPENAI_API_KEY=sk-여기에-OpenAI-API-키

# 선택: 번역 모델 (기본 gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini
